{
  "name": "pi-cc-router",
  "version": "0.1.0",
  "description": "Pi coding agent extension that routes LLM calls through Claude Code CLI",
  "main": "index.ts",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "index.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xonika9/pi-cc-router"
  },
  "license": "MIT",
  "peerDependencies": {
    "@mariozechner/pi-ai": "^0.52.0",
    "@mariozechner/pi-coding-agent": "^0.52.0"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "test": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  }
}
